{
  "openapi": "3.0.0",
  "info": {
    "title": "Release Workflow API",
    "description": "API contract for automated release workflow of transformed Hungarian electoral address data",
    "version": "1.0.0"
  },
  "paths": {
    "/release/create": {
      "post": {
        "summary": "Create a new release package",
        "description": "Packages transformed data files and creates GitHub release",
        "operationId": "createRelease",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "release_tag": {
                    "type": "string",
                    "pattern": "^\\d{8}-\\d{4}$",
                    "description": "Release tag in YYYYMMDD-HHMM format"
                  },
                  "data_version": {
                    "type": "string",
                    "description": "Version identifier from transformation pipeline"
                  },
                  "change_summary": {
                    "type": "string",
                    "description": "Summary of changes since last release"
                  }
                },
                "required": ["release_tag", "data_version"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Release created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "release_id": {
                      "type": "string",
                      "description": "Unique identifier for the release"
                    },
                    "release_tag": {
                      "type": "string",
                      "description": "Release tag used"
                    },
                    "github_release_url": {
                      "type": "string",
                      "description": "URL to the created GitHub release"
                    },
                    "artifacts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "artifact_type": {
                            "type": "string",
                            "enum": ["csv_archive", "database_archive"]
                          },
                          "file_path": {
                            "type": "string"
                          },
                          "file_size": {
                            "type": "integer"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request or validation failed"
          },
          "500": {
            "description": "Internal server error during release creation"
          }
        }
      }
    },
    "/release/validate": {
      "post": {
        "summary": "Validate data before release",
        "description": "Validate data integrity and completeness before creating release",
        "operationId": "validateReleaseData",
        "responses": {
          "200": {
            "description": "Data validation passed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "valid": {
                      "type": "boolean",
                      "description": "Whether data validation passed"
                    },
                    "checks": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "check_name": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string",
                            "enum": ["passed", "failed"]
                          },
                          "message": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Data validation failed"
          }
        }
      }
    },
    "/release/cleanup": {
      "post": {
        "summary": "Clean up temporary files",
        "description": "Remove temporary files created during release process",
        "operationId": "cleanupRelease",
        "responses": {
          "200": {
            "description": "Cleanup completed successfully"
          },
          "500": {
            "description": "Cleanup failed"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ReleasePackage": {
        "type": "object",
        "properties": {
          "release_id": {
            "type": "string"
          },
          "release_tag": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "data_version": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "created", "failed"]
          },
          "change_summary": {
            "type": "string"
          },
          "github_release_url": {
            "type": "string"
          }
        }
      },
      "ReleaseArtifact": {
        "type": "object",
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "release_id": {
            "type": "string"
          },
          "artifact_type": {
            "type": "string",
            "enum": ["csv_archive", "database_archive"]
          },
          "file_path": {
            "type": "string"
          },
          "file_size": {
            "type": "integer"
          },
          "checksum": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}